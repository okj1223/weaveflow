{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weaveflow.local/schemas/status.schema.json",
  "title": "Weaveflow Status JSON Output",
  "type": "object",
  "required": [
    "contract_version",
    "workspace_exists",
    "workspace_path",
    "state_db_path",
    "memory_path",
    "task_count",
    "tasks"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "weaveflow.v1"
    },
    "workspace_exists": {
      "type": "boolean"
    },
    "workspace_path": {
      "type": "string"
    },
    "state_db_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "memory_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "task_count": {
      "type": "integer",
      "minimum": 0
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": [
        "id",
        "title",
        "status",
        "created_at",
        "updated_at"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^TASK-[0-9]{4}$"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "planned",
            "briefed",
            "result_attached",
            "verifying",
            "verified",
            "completed",
            "blocked",
            "failed"
          ]
        },
        "created_at": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        }
      }
    }
  }
}
